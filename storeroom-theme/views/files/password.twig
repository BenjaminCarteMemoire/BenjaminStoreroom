{% extends 'layout/base.twig' %}

{% block sidebar_title %}
    {{ __( 'Page information', 'storeroom' ) }}
{% endblock %}

{% block sidebar_content %}
    <ul class="sidebar_list">
        <li>
            <span class="sidebar_list_li_title">{{ __( 'Filename: ', 'storeroom') }}</span>
            {{ post.title }}
        </li>
        <li>
            <span class="sidebar_list_li_title">{{ __( 'Posted by: ', 'storeroom') }}</span>
            <a class="sidebar_author" href="{{ post.author.profile_url }}">{{ post.author.name }}</a>
        </li>
        <li>
            <span class="sidebar_list_li_title">{{ __( 'Date: ', 'storeroom' ) }}</span>
            {{ post.date }}
        </li>
        <li>
            <span class="sidebar_list_li_title">{{ __( 'Sections: ', 'storeroom' ) }}</span>
            <ul>
                {% for term in post.terms({ taxonomy: 'files-sections' }) %}
                    <li>
                        <a class="sidebar_author" href="{{ term.link }}">{{ term.title }}</a>
                    </li>
                {% else %}
                    <li>
                        {{ __( "None", 'storeroom') }}
                    </li>
                {% endfor %}
            </ul>
        </li>
    </ul>
{% endblock %}

{% block page_title %}
 {{ __( 'File protection', 'storeroom') }}
{% endblock %}

{% block page_content %}
 {{ form }}
{% endblock %}